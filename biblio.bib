@techreport{ifremer_systeme_dinformations_halieutiques_structure_2025,
	title = {Structure de la flotte de pêche française et répartition spatiale de son activité en {Atlantique} {Nord}-{Est} en 2023},
	url = {https://archimer.ifremer.fr/doc/01005/111691/},
	doi = {10.13155/111691},
	abstract = {qui pêche où, comment, quoi et combien ? l’objectif de ce document, proposé par le sih de l’ifremer, est de fournir une description détaillée de la flotte de pêche professionnelle française active en atlantique nord-est en 2023, en s’appuyant sur les données les plus complètes disponibles au sein du sih. une attention particulière est portée à la dimension spatiale des activités, un élément clé pour comprendre les enjeux multiples auxquels la pêche est confrontée dans toute sa diversité.quelques indicateurs clés sur les caractéristiques de navires (nombre, puissance motrice et tonnage), l’effort de pêche (heures de pêche et kwh) ainsi que la production (quantités et valeur débarquées) sont croisés par classe de longueur des navires engins de pêche, flottilles et régions. l’apport original est notamment la spatialisation de certains indicateurs à macro-échelle, selon plusieurs espaces maritimes : i) eaux intérieures et mer territoriale, ii) zone des 12-24 milles, iii) zone des 24-200 milles, et iv) zones sous souveraineté étrangère.cette approche met en lumière les fortes disparités de dépendance économique des navires à ces espaces, ainsi que leur contribution respective à la production globale et par espèce. ce travail contribue également à une meilleure objectivation de la répartition spatiale des pressions exercées selon la taille des navires, le type d’engins employés, et leur répartition spatiale.des représentations cartographiques plus fines, basées sur les données de géolocalisation, sont proposées. elles illustrent l’activité de pêche par classe de taille, par type d’engins et par espèce, permettant une compréhension plus précise de la distribution spatiale des activités et des contraintes liées notamment à la disponibilité des ressources.},
	language = {fr},
	urldate = {2026-05-20},
	institution = {Ifremer. Système d'Informations Halieutiques},
	author = {Ifremer. Système d'Informations Halieutiques},
	month = dec,
	year = {2025},
	file = {Full Text PDF:C\:\\Users\\damien.le-guyader\\Zotero\\storage\\I6NVT9YY\\2025 - Structure de la flotte de pêche française et répartition spatiale de son activité en Atlantique Nord.pdf:application/pdf},
}

