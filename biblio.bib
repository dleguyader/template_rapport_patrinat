@techreport{de_bettignies_indicateurs_2025,
	title = {Indicateurs d'évaluation de l'état de santé des habitats benthiques marins : synthèse en appui aux gestionnaires d'aires marines protégées},
	shorttitle = {Indicateurs d'évaluation de l'état de santé des habitats benthiques marins},
	url = {https://hal.science/hal-05282999},
	abstract = {Cette étude s’inscrit dans un contexte d’évaluation de l’état de santé des habitats benthiques marins en appui aux politiques publiques. Le rapport a été conçu pour aider les gestionnaires d’aires marines protégées à choisir des indicateurs permettant d’évaluer l’efficacité des mesures de conservation, notamment la mise en place de zones de protection forte. Ce rapport recense les indicateurs stationnels utilisés en France hexagonale et Corse. Pour chaque indicateur, une fiche synthétique présente les informations essentielles offrant ainsi une vue d’ensemble de l’indicateur, depuis son déploiement sur le terrain jusqu’à son calcul. Ce rapport synthétise également l’opérabilité de l’indicateur, ses limites, ses avantage et sa sensibilité vis-à-vis des pressions anthropiques. Au total, 34 indicateurs sont décrits, organisés suivant la façade maritime et la nature du substrat. Les fiches-indicateurs détaillées sont également disponibles en ligne via le Catalogue interactif des indicateurs OFB et en annexe (Annexe I) de ce présent rapport. Pour chaque fiche, un travail a été effectué pour identifier les unités d’habitats succeptibles d’être évaluées par les indicateurs selon les typologies nationales NatHab-Atlantique et NatHab-Méditerranée. Il est également précisé dans chaque fiche si l’indicateur peut contribuer ou non à l'évaluation des Groupes de Types d’habitats marins listés dans le Règlement relatif à la restauration de la nature. L’étude a permis de compléter deux « catalogues » consultables en ligne : - le Catalogue des indicateurs (https://catalogueindicateursamp.ofb.fr) qui vise à mettre à disposition des gestionnaires un outil de partage d’informations, permettant d’identifier, de décrire et de sélectionner les indicateurs pertinents pour renseigner et faciliter la gestion des AMP. - le Catalogue CAMPanule (https://campanule.mnhn.fr) qui rassemble et caractérise les techniques, méthodes et protocoles de collecte de données naturalistes en France. Il a pour objectif de servir de référentiel pour la bancarisation des données naturalistes. Sachant les travaux en continu sur le développement et la calibration d’indicateurs stationnels de l’état écologique des habitats benthiques marins, ce travail de compilation et de synthèse représente l’état des connaissances en 2025 et a vocation à être actualisé selon les avancées des connaissances.},
	urldate = {2026-03-09},
	institution = {PatriNat (OFB-CNRS-MNHN-IRD)},
	author = {de Bettignies, Florian and Beauvais, Sophie and Janson, Anne-Laure and Gamp, Elodie and Gazay, Camille and La Rivière, Marie and de Bettignies, Thibaut},
	month = oct,
	year = {2025},
	keywords = {Aires Marines Protégées, Evaluation écologique, Habitat marin, Indicateur, Mesure de conservation, Zone de protection forte},
	pages = {95},
	file = {HAL PDF Full Text:C\:\\Users\\damien.le-guyader\\Zotero\\storage\\5Y93AEUP\\de Bettignies et al. - 2025 - Indicateurs d'évaluation de l'état de santé des habitats benthiques marins  synthèse en appui aux g.pdf:application/pdf},
}

@article{sutherland_nine_2026,
	title = {Nine changes needed to deliver a radical transformation in biodiversity measurement},
	volume = {123},
	url = {https://www.pnas.org/doi/10.1073/pnas.2519345123},
	doi = {10.1073/pnas.2519345123},
	abstract = {Biodiversity is declining in many parts of the world. Biological diversity measurement and monitoring are fundamental to the assessment of the causes and consequences of environmental changes, identification of key areas for the protection of biodiversity or ecosystem services, determining the effectiveness of actions, and the creation of decision-support tools critical to maintaining a sustainable planet. Biodiversity measurement is rapidly changing due to advances in citizen science, image recognition, acoustic monitoring, environmental DNA, genomics, remote sensing, and AI. In this perspective, we outline the exciting opportunities these developments offer but also consider the challenges. Our key recommendations are to 1) Capitalize on the ability of novel technology to integrate data sources 2) agree to standard methods for data collection 3) ensure new technologies are calibrated with existing data; 4) fill data gaps by using emerging technologies and increasing capacity, especially in the tropics; 5) create living safeguarded databases of trusted information to reduce the risk of poisoning by AI hallucinated, or false, information; 6) ensure data generation is valued; 7) ensure respectful incorporation of Indigenous Knowledge; 8) ensure measurements enable the quantification of effectiveness of actions, and 9) increase the resilience of global datasets to technical and societal change. Radical new collaborations are needed between computer scientists, engineers, molecular biologists, data scientists, field ecologists, citizen scientists, Indigenous peoples, policymakers, and local communities to create the rigorous, resilient, accessible biodiversity information systems required to underpin policies and practices that ensure the maintenance and restoration of ecological systems.},
	number = {10},
	urldate = {2026-03-11},
	journal = {Proceedings of the National Academy of Sciences},
	publisher = {Proceedings of the National Academy of Sciences},
	author = {Sutherland, William J. and Burgess, Neil D. and Edwards, Scott V. and Jones, Julia P. G. and Soltis, Pamela S. and Tilman, David and Allen, Julie M. and Andrianandrasana, Herizo T. and Armour, Cathrine J. and August, Tom and Bawa, Kamaljit S. and Bailey, Sallie and Birch, Tanya and Boersch-Supan, Philipp H. and Cavender-Bares, Jeannine and Blaxter, Mark and Chaplin-Kramer, Rebecca and Daru, Barnabas H. and De Palma, Adriana and Eisenberg, Cristina and Elphick, Chris S. and Freckleton, Robert P. and Frick, Winifred F. and Gonzalez, Andrew and Goetz, Scott J. and Greenspoon, Lior and Grozingeree, Christina M. and Hankins, Don L. and Hazell, Jonny and Isaac, Nick J. B. and Lambertini, Marco and Lewin, Harris A. and Mac Aodha, Oisin and Madhavapeddy, Anil and Milner-Gulland, EJ and Milo, Ron and O’Dwyer, James and Purvis, Andy and Salafsky, Nick and Tallis, Heather and Tanshi, Iroro and Vijay, Varsha and Wikelski, Martin and Williams, David R. and Woodard, S. Hollis and Robinson, Gene E.},
	month = mar,
	year = {2026},
	pages = {e2519345123},
	file = {Full Text PDF:C\:\\Users\\damien.le-guyader\\Zotero\\storage\\TRPU7BDS\\Sutherland et al. - 2026 - Nine changes needed to deliver a radical transformation in biodiversity measurement.pdf:application/pdf},
}

@article{lecomte_human_2026,
	title = {The {Human} {Pressure} {Index} ({HPI}): integrating cumulative anthropogenic pressures into {SEEA}-{EA} ecosystem condition accounts},
	volume = {185},
	issn = {1470-160X},
	shorttitle = {The {Human} {Pressure} {Index} ({HPI})},
	url = {https://www.sciencedirect.com/science/article/pii/S1470160X26001962},
	doi = {10.1016/j.ecolind.2026.114796},
	abstract = {Effective ecosystem assessment and environmental planning require spatially explicit indices capturing how human-driven stressors affect ecosystems. Global assessments, including IPBES, identify land-use change, pollution, and invasive alien species (IAS) as major drivers of biodiversity loss. Yet these pressures remain insufficiently operationalised within ecosystem accounting frameworks such as SEEA-EA, limiting their direct policy application. To bridge this gap, we propose a pressure-based conceptual framework aligned with the hierarchical structure of SEEA-EA ecosystem condition, which explicitly distinguishes anthropogenic pressures from ecosystem state variables and enables their systematic representation within ecosystem accounting. We operationalise this framework through the Human Pressure Index (HPI), a harmonised and spatially explicit composite index for European terrestrial ecosystems. HPI integrates 16 pressure indicators into three modular pressure-specific indices aligned with the IPBES drivers (land-use, pollution, and IAS), enabling both cumulative and driver-specific analyses. HPI shows a strong negative association with the Biodiversity Intactness Index (BII), with pollution emerging as the strongest correlate of BII variation. A GAM–Beta model captures nonlinear biodiversity responses along the pressure gradient, explaining 40\% of deviance and revealing saturation effects at high pressure levels. Comparisons with the Global Human Modification (GHM) index highlight complementarities between structural modification (GHM) and diffuse functional pressures (HPI). Overall, this study provides a scalable and transferable pressure-based framework for the systematic integration of anthropogenic pressures within ecosystem condition assessment. HPI offers a policy-ready, spatially explicit tool for mapping cumulative pressures across ecosystems and supports environmental monitoring, policy evaluation and strategic planning across governance levels.},
	urldate = {2026-03-23},
	journal = {Ecological Indicators},
	author = {Lecomte, Xavier and Aubard, Valentine and Rusch, Graciela M. and Czúcz, Bálint and Tanács, Eszter and Thomas, Isabel Nicholson and Cortinovis, Chiara and Vallecillo, Sara and Seguin, Joana and Santos-Martín, Fernando and Grêt-Regamey, Adrienne and Roche, Philip},
	month = apr,
	year = {2026},
	keywords = {Cumulative anthropogenic pressures, Ecosystem condition assessment, Environmental policy impact assessment, IPBES drivers, Pressure-based conceptual framework, SEEA ecosystem accounting},
	pages = {114796},
	file = {Lecomte-etal_2026-mmc1:C\:\\Users\\damien.le-guyader\\Zotero\\storage\\SYFQVJR8\\Lecomte-etal_2026-mmc1.docx:application/vnd.openxmlformats-officedocument.wordprocessingml.document;ScienceDirect Full Text PDF:C\:\\Users\\damien.le-guyader\\Zotero\\storage\\NBGSIAZJ\\Lecomte et al. - 2026 - The Human Pressure Index (HPI) integrating cumulative anthropogenic pressures into SEEA-EA ecosyste.pdf:application/pdf;ScienceDirect Snapshot:C\:\\Users\\damien.le-guyader\\Zotero\\storage\\BNW4VAG6\\S1470160X26001962.html:text/html},
}

@article{virtanen_impacts_2026,
	title = {Impacts of diffuse pressure complexes complicate conservation and management of benthic marine habitats},
	volume = {63},
	copyright = {© 2025 The Author(s). Journal of Applied Ecology published by John Wiley \& Sons Ltd on behalf of British Ecological Society.},
	issn = {1365-2664},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/1365-2664.70247},
	doi = {10.1111/1365-2664.70247},
	abstract = {Human activities exert considerable pressures on marine ecosystems, causing widespread habitat loss (direct footprint) and degradation (diffuse pressures). Cumulative effect assessments are widely used to evaluate pressures, but their utility in spatial management remains limited due to their typically coarse resolution. Importantly, effects interpreted as additive or synergistic at broad scales may not be such when analysed with high-resolution data. We compiled high-resolution spatial data on human activities, capturing both coastal land use and activities at sea, and estimated their associated pressures and impacts on benthic ecosystems in Finland, northern Baltic Sea. Through hierarchical clustering, we identified ‘pressure complexes’, broader areas where different human activities co-occur with varying composition. We further evaluated eutrophication profiles of these clusters, the main environmental problem of the Baltic Sea, and quantified the relative severity of human activities on benthic habitats using detailed species distribution models. We identified three pressure clusters, primarily driven by recreational activities, industrial sea use, and maritime traffic. Many activities were spatially confined, especially in archipelago areas, but their diffuse pressures co-occurred, impacting the same region and similar habitats. Diffuse pressures had one to two orders of magnitude larger spatial impact on benthic habitats than activities causing direct habitat loss. Recreational activities and coastal land use emerged as the most detrimental drivers of habitat degradation, despite their limited spatial extent. Nutrient concentrations were elevated in all pressure clusters, indicating that diffuse pressures, caused by various human activities, act in synergy with coastal eutrophication, amplifying their effects and complicating their management. Policy implications. Our results suggest that pressures in marine ecosystems often arise from numerous seemingly minor activities that collectively contribute to substantial habitat degradation. They underscore the urgent need to develop more targeted, local management measures that address detrimental small-scale activities. In our study area, such measures could include regulating dredging (e.g. through permitting), limiting recreational boating in ecologically most sensitive areas, and developing guidelines for coastal development. Stricter regulation should be imposed particularly in areas with limited water exchange, where these activities likely amplify pressures on already degraded ecosystems.},
	language = {en},
	number = {1},
	urldate = {2026-04-15},
	journal = {Journal of Applied Ecology},
	author = {Virtanen, Elina A. and Forsblom, Louise and Kaikkonen, Laura and Kallio, Niko and Korpinen, Samuli and Takolander, Antti and Wärri, Tytti and Viitasalo, Markku},
	year = {2026},
	note = {\_eprint: https://besjournals.onlinelibrary.wiley.com/doi/pdf/10.1111/1365-2664.70247},
	keywords = {cumulative effects, habitat condition, human activities, marine biodiversity, pressures, sea use change},
	pages = {e70247},
	file = {Full Text PDF:C\:\\Users\\damien.le-guyader\\Zotero\\storage\\9EZIIXXR\\Virtanen et al. - 2026 - Impacts of diffuse pressure complexes complicate conservation and management of benthic marine habit.pdf:application/pdf;Snapshot:C\:\\Users\\damien.le-guyader\\Zotero\\storage\\2N9EGB52\\1365-2664.html:text/html},
}

@article{kallio_challenges_2025,
	title = {Challenges in expert ratings of marine habitat and species sensitivity to anthropogenic pressures},
	volume = {15},
	copyright = {2025 The Author(s)},
	issn = {2045-2322},
	url = {https://www.nature.com/articles/s41598-025-96913-8},
	doi = {10.1038/s41598-025-96913-8},
	abstract = {Expert knowledge can help fill gaps in quantitative empirical information about complex ecological phenomena. We examined the level of agreement between 21 studies that collected expert ratings of the sensitivity of species and habitats to human activities and their pressures as input data for mapping the human impact on marine ecosystems. Our analyses revealed broad agreement about which human activities and pressures many species and habitats are sensitive to. These agreements reflect a common view of the main threats to ocean ecosystems. In contrast, scores provided by individual experts varied both within and across studies. Sensitivity scores collected with the same method for different regions were often more similar than scores collected for the same region but with different methods. These results highlight how inconsistencies in the design of many expert surveys can lead to variable outcomes. It is important to employ more consistent and theoretically grounded methods and protocols when eliciting expert ratings of species’ sensitivity to pressures, to ensure compatibility across studies and maintain rigour in analyses supporting effective ocean management.},
	language = {en},
	number = {1},
	urldate = {2026-04-15},
	journal = {Scientific Reports},
	publisher = {Nature Publishing Group},
	author = {Kallio, Niko and Andersen, Jesper H. and Carstensen, Jacob and Gissi, Elena and Halpern, Benjamin S. and Hammar, Linus and Murray, Ciaran and Stelzenmüller, Vanessa and Stock, Andy and Korpinen, Samuli},
	month = apr,
	year = {2025},
	keywords = {Ecosystem ecology, Environmental impact, Marine biology},
	pages = {12546},
	file = {Full Text PDF:C\:\\Users\\damien.le-guyader\\Zotero\\storage\\DEP4NNRT\\Kallio et al. - 2025 - Challenges in expert ratings of marine habitat and species sensitivity to anthropogenic pressures.pdf:application/pdf},
}

