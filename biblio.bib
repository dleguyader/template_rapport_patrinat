	issn = {0025326X},
	shorttitle = {An ecosystem-based index for {Mediterranean} coralligenous reefs},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S0025326X25008501},
	doi = {10.1016/j.marpolbul.2025.118375},
	abstract = {Coralligenous reefs are among the most diverse Mediterranean ecosystems, particularly in the circalittoral zone. Shaped by calcified red algae, sponges, cnidarians, and bryozoans, they create a complex three-dimensional structure providing shelter for diverse fauna. These reefs develop either on steep rocky walls or as bioherms when calcified algae are the dominant organisms. Their structure and composition vary with location, depth, substrate, and environmental conditions.},
	language = {en},
	urldate = {2026-03-09},
	journal = {Marine Pollution Bulletin},
	author = {Astruch, Patrick and Boudouresque, Charles-François and Cabral, Mélanie and Schohn, Thomas and Ballesteros, Enric and Bellan-Santini, Denise and Belloni, Bruno and Bianchi, Carlo Nike and Cassetti, Olivia and Chevaldonné, Pierre and Fourt, Maïa and Guidetti, Paolo and Hartmann, Virginie and Jacob, Élodie and Le Diréach, Laurence and Michez, Noëmie and Montefalcone, Monica and Morri, Cala and Nérini, David and Pérez, Thierry and Pibot, Alain and Poggiale, Jean-Christophe and Reveret, Claude and Valance, Félix and Ruitton, Sandrine and Sartoretto, Stéphane and Blouet, Sylvain and Ricquiers, Laurent and Thibaut, Thierry and Vacelet, Jean and Verlaque, Marc},
